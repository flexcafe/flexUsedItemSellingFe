{
  "expo": {
    "name": "Flex Used Market",
    "slug": "flex-used-market-fe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flexusedmarket",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flexusedmarket.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "fb",
          "fbapi",
          "fb-messenger-share-api"
        ]
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#FFF7ED",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.flexusedmarketfe"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#FFF7ED",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Flex Used Market to verify your registration region."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Flex Used Market to access your photos for profile avatars and Facebook follow proof screenshots."
        }
      ],
      [
        "react-native-fbsdk-next",
        {
          "appID": "874871261609348",
          "clientToken": "c0c7165def84af13fe58bfa0df5bff30",
          "displayName": "Flex Used Market",
          "scheme": "fb874871261609348",
          "advertiserIDCollectionEnabled": false,
          "autoLogAppEventsEnabled": false,
          "isAutoInitEnabled": true
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "476f125c-2259-465c-be76-480a4180a067"
      }
    },
    "owner": "mhkhizl"
  }
}
